{
    "version": "2.0.0",
    "windows": {
        "command": "nmake",
        "options": {
            "env": {
                "Path": "${env:Path};${env:VCINSTALLDIR}Tools/Llvm/bin"
            }
        }
    },
    "tasks": [
        {
            "type": "shell",
            "label": "Build Debug Executable",
            "windows": {
                "args": [
                    "\"DEBUG_BUILD=true\"",
                    "clearscreen",
                    "clean",
                    "debug.exe"
                ]
            },
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "type": "shell",
            "label": "Build Release Executable",
            "windows": {
                "args": [
                    "clearscreen",
                    "clean",
                    "release.exe"
                ]
            },
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:\\msys64\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}